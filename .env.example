# Copy this to .env and fill in real values before running docker compose up

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-long-random-string

# PostgreSQL password
DB_PASSWORD=replace-with-a-strong-password

# Comma-separated list of domains Django will accept requests for
# Local testing:  localhost
# Production:     yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost

# Origins allowed to make API requests (no trailing slash)
# Local testing:  http://localhost
# Production:     https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost

# Host port to expose the app on (default 80)
PORT=80
